# config/config.sh — copy to config/config.sh and customize (not committed if gitignored)
#
# cp config/config.sh.example config/config.sh
#
# DEST_ROOT is always a locally mounted path (travel SSD or NAS shared folder), never “the server”.

# macOS travel SSD
# DEST_ROOT="/Volumes/Extreme SSD/PhotoVault/CardMirror"

# macOS home — NAS share mount
# DEST_ROOT="/Volumes/Photos/PhotoVault/CardMirror"

# Ubuntu headless media server — NAS share mount (NFS/CIFS), e.g. /mnt/photos → PhotoVault
# DEST_ROOT="/mnt/photos/PhotoVault/CardMirror"
# CARD_MOUNT_ROOTS="/media/${USER}:/run/media/${USER}"

# KEEP_DAYS=90
# FAST_MODE=1
# DRY_RUN=0
